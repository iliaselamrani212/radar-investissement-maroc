# ═══════════════════════════════════════════════════════════════
# Radar SDG Capital - Configuration (LLM local via Ollama)
# ═══════════════════════════════════════════════════════════════
# Aucune clé API à fournir : tout tourne en local !

# === OLLAMA (LLM LOCAL) ===
# URL du serveur Ollama (par défaut localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Modèle utilisé : Qwen 2.5 7B (excellent en multilingue dont français)
# Alternatives : qwen2.5:14b (meilleure qualité mais 2x plus lent),
#                qwen2.5:3b (rapide mais moins fiable)
OLLAMA_MODEL=qwen2.5:7b

# Timeout en secondes
# GPU : 60s suffit. CPU pur : 180s recommandé.
OLLAMA_TIMEOUT=180


# === BASE DE DONNÉES ===
# SQLite par défaut (zero config, parfait pour MVP)
# Pour PostgreSQL en production : décommenter et adapter
# DATABASE_URL=postgresql://user:password@localhost:5432/radar_sdg


# === LOGGING ===
LOG_LEVEL=INFO
